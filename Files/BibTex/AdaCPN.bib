@article{XUE2026104849,
title = {Exploring contextual and pairwise semantic-enhanced embedding with adaptive fusion for knowledge graph completion},
journal = {Information Processing \& Management},
volume = {63},
number = {7, Part B},
pages = {104849},
year = {2026},
issn = {0306-4573},
doi = {https://doi.org/10.1016/j.ipm.2026.104849},
url = {https://www.sciencedirect.com/science/article/pii/S0306457326002402},
author = {Zengcan Xue and Jiarui Chen and Xiaoyong Hu and Zirou Lin},
keywords = {Knowledge graph completion, Adaptive convolution, Hybrid-granularity semantic, Link prediction},
abstract = {Knowledge Graph Completion (KGC) aims to predict missing facts by embedding entities and relations, emerging as the predominant method for intelligent reasoning. However, existing KGC approaches tend to ignore the potential noise and uncertainty, as the contribution of each connected relation to entities varies across distinct link scenarios. Moreover, the simple aggregation process during embedding learning struggles to capture both global and local information simultaneously. To overcome these issues, this paper proposes the Adaptive Contextual-Pairwise Network (AdaCPN) model. Specifically, hybrid-granularity semantic augmentation derives a contextual representation of triplets by attending to the surrounding feature information, and suppressing redundant semantic information. Furthermore, it boosts predictive semantics with pairwise frequency weights of triplets, achieving dynamic contribution allocation and alleviating semantic distribution disparity. Additionally, AdaCPN utilizes adaptive convolution kernels of distinct sizes to broaden the receptive field, which fuses global and detailed features during the aggregation process. AdaCPN is validated on nine benchmark datasets, containing millions of triplets. Experimental results confirm that in MRR on FB15k-237 and WN18RR, AdaCPN not only outperforms neural network-based SOTA methods with improvements of 5.8\% and 3.4\% (0.430 vs. 0.372, 0.551 vs. 0.517), but also improves by 3.8\% and 0.2\% (0.430 vs. 0.392, 0.551 vs. 0.549) compared to LLM-based SOTA approaches.}
}